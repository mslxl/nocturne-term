{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nocturne",
  "version": "0.1.0",
  "identifier": "com.mslxl.nocturne",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "nocturne",
        "width": 800,
        "height": 600,
        "decorations": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "mslxl",
    "category": "DeveloperTool",
    "shortDescription": "A native-feeling cross-platform terminal app.",
    "longDescription": "Nocturne is a cross-platform terminal app for macOS, Linux, Windows, Android, and iOS, built for a native-feeling experience with a clean interface and fast everyday use.",
    "licenseFile": "../LICENSE",
    "resources": [
      "resources/nocturne-terminal-agent/**/*",
      "resources/nocturne-resource-monitor-agent/**/*",
      "resources/ripgrep/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
